# Analytics worker configuration
NODE_ENV=development

# Pub/Sub
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
ANALYTICS_PUBSUB_TOPIC=user-behavior-events
ANALYTICS_PUBSUB_SUBSCRIPTION=user-behavior-events-sub
ANALYTICS_PUBSUB_DEAD_LETTER_TOPIC=user-behavior-events-dead-letter
ANALYTICS_PUBLISH_DEAD_LETTER=true

# Analytics DB (recommended separate DB/schema)
ANALYTICS_MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net
ANALYTICS_DB_NAME=analytics
ANALYTICS_DB_MAX_POOL_SIZE=40
ANALYTICS_DB_MIN_POOL_SIZE=5

# Worker performance
ANALYTICS_WORKER_BATCH_SIZE=1000
ANALYTICS_WORKER_FLUSH_INTERVAL_MS=2000
ANALYTICS_WORKER_MAX_MESSAGES=2000
ANALYTICS_RAW_EVENTS_TTL_DAYS=90
ANALYTICS_WORKER_HEALTH_COLLECTION=worker_health
ANALYTICS_WORKER_HEALTH_INTERVAL_MS=10000
ANALYTICS_WORKER_STALE_THRESHOLD_MS=60000
